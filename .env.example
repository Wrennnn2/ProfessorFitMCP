# OpenAlex 礼貌池（填邮箱后速率更高，非必须）
OPENALEX_EMAIL=your@email.com

# 教授资料库路径（默认当前目录）
PROFESSOR_PROFILES_DB_PATH=professor_profiles.db

# find_professors 自动保存 Markdown 结果的目录（默认当前目录）
PROFESSOR_FIT_OUTPUT_DIR=./results

# LLM 查询意图分析（可选，不配置则使用规则回退）
# 兼容 OpenAI / Deepseek / 任何 OpenAI-compatible API
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
